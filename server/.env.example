GOOGLE_PLACES_API_KEY=AIza...your_server_key_here
PORT=5050
TRUST_PROXY=true

# Comma-separated frontend origins when the API is on a different domain.
# Example: https://maptivity.ai,https://www.maptivity.ai
ALLOWED_ORIGINS=

# In-memory per-IP rate limits. Tune these after real traffic arrives.
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=300
PLACES_RATE_LIMIT_WINDOW_MS=60000
PLACES_RATE_LIMIT_MAX_REQUESTS=60
PHOTO_RATE_LIMIT_WINDOW_MS=60000
PHOTO_RATE_LIMIT_MAX_REQUESTS=120
PLANNER_RATE_LIMIT_WINDOW_MS=60000
PLANNER_RATE_LIMIT_MAX_REQUESTS=10

# Optional local itinerary generation. For production, either run an Ollama
# service reachable by this URL or hide/disable generated planner features.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest
